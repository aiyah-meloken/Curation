{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Curation",
  "version": "0.1.98",
  "identifier": "com.zhuhuifeng.curation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Curation\uff1a\u4f60\u7684\u4e13\u5c5e\u8d44\u8baf\u52a9\u7406",
        "width": 1200,
        "height": 750
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https: ipc:; connect-src 'self' ipc: http://127.0.0.1:8889 http://localhost:8889 ws: wss: https:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' tauri: https: http://wx.qlogo.cn http://mmbiz.qpic.cn data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJEOTU4NEZFODNDRjMzMTIKUldRU004K0Qvb1NWdmI0emwxamRNckw0WTRHL1RuTzdETEpVZ1Badmt0OEkwMGlIMTZYVVNuYTMK",
      "endpoints": [
        "https://github.com/curation-x3/Curation/releases/latest/download/latest.json"
      ]
    }
  }
}
